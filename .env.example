# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# AI (skill tree + lesson generation via Amazon Bedrock)
AWS_BEDROCK_REGION=us-east-1
# Preferred if you generated an Amazon Bedrock API key:
AWS_BEARER_TOKEN_BEDROCK=
# Optional IAM credentials instead of AWS_BEARER_TOKEN_BEDROCK:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: override both generation routes to a single model.
# Default: graph generation uses Opus 4.7, lesson generation uses Sonnet 4.6.
BEDROCK_MODEL_ID=

# MCP server credentials
MEM0_API_KEY=
FIRECRAWL_API_KEY=
GITHUB_PAT_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
